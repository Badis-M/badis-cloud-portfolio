---
import "../styles/portfolio.css";
import { portfolioContent, portfolioLinks } from "../data/portfolioContent";

type PortfolioContent = (typeof portfolioContent)[keyof typeof portfolioContent];

const page = (Astro.props.content ?? portfolioContent.en) as PortfolioContent;
---


<html lang={page.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>

  <body>
    <main class="page">
      <header class="header">
        <a class="logo" href="/">Badis Merakchi</a>
        <div class="header-actions">
          <div class="language-switch" aria-label={page.languageLabel}>
            <a class:list={[page.lang === "en" && "active"]} href="/">EN</a>
            <a class:list={[page.lang === "fr" && "active"]} href="/fr">FR</a>
          </div>
        </div>
      </header>

      <aside class="side-nav" aria-label={page.lang === "fr" ? "Navigation des sections" : "Section navigation"}>
        <a class="active" href="#skills" data-section="skills">
          <span></span>
          {page.nav.skills}
        </a>
        <a href="#experience" data-section="experience">
          <span></span>
          {page.nav.experience}
        </a>
        <a href="#projects" data-section="projects">
          <span></span>
          {page.nav.projects}
        </a>
        <a href="#contact" data-section="contact">
          <span></span>
          {page.nav.contact}
        </a>
      </aside>

      <section class="hero">
        <div class="hero-copy">
          <p class="status">{page.hero.status}</p>

          <h1>{page.hero.title}</h1>

          <p class="lead">{page.hero.lead}</p>

          <div class="actions">
            <a class="button primary" href={portfolioLinks.cv}>{page.hero.cvButton}</a>
            <a class="button secondary" href={portfolioLinks.github} target="_blank" rel="noopener noreferrer">GitHub ↗</a>
            <a class="button secondary" href={portfolioLinks.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a>
          </div>
        </div>

        <aside class="profile-card">
          <div class="card-header">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="availability-badge">
            <span></span>
            {page.hero.availability}
          </div>

          {page.hero.metrics.map(([label, value]) => (
            <div class="metric">
              <p>{label}</p>
              <strong>{value}</strong>
            </div>
          ))}
        </aside>
      </section>

      <section id="skills" class="section">
        <div class="section-head">
          <p>{page.skillsSection.eyebrow}</p>
          <h2>{page.skillsSection.title}</h2>
        </div>

        <div class="skills-grid">
          {page.skills.map(([label, value]) => (
            <div class="skill-card">
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </div>
      </section>

      <section id="experience" class="section">
        <div class="section-head">
          <p>{page.experienceSection.eyebrow}</p>
          <h2>{page.experienceSection.title}</h2>
        </div>

        <article class="experience">
          <div class="experience-header">
            <div>
              <h3>Oracle — Cloud Consultant</h3>
              <span>{page.experienceSection.oracleLocation}</span>
            </div>

            <p>{page.experienceSection.oracleDescription}</p>
          </div>

          <div class="experience-columns">
            <div>
              <h4>{page.experienceSection.clientsTitle}</h4>
              <div class="client-list">
                {page.clientEnvironments.map((client) => <span>{client}</span>)}
              </div>
            </div>

            <div>
              <h4>{page.experienceSection.missionsTitle}</h4>
              <div class="mission-list">
                {page.missionAreas.map((mission) => <span>{mission}</span>)}
              </div>
            </div>
          </div>
        </article>

        <div class="additional-experience-grid">
          {page.additionalExperiences.map((item) => (
            <article class="additional-experience-card">
              <div>
                <span>{item.company}</span>
                <h3>{item.role}</h3>
              </div>

              <p>{item.description}</p>

              <div class="compact-tags">
                {item.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="section">
        <div class="section-head">
          <p>{page.projectsSection.eyebrow}</p>
          <h2>{page.projectsSection.title}</h2>
        </div>

        <article class="featured-project-card">
          <div class="featured-copy">
            <div class="featured-topline">
              <p class="featured-label">{page.projectsSection.featuredLabel}</p>
              <span>{page.projectsSection.featuredType}</span>
            </div>

            <h3>{page.featuredProject.title}</h3>
            <p>{page.featuredProject.description}</p>
            <p class="featured-proof">{page.featuredProject.proof}</p>

            <div class="featured-metrics">
              {page.featuredProject.metrics.map(([label, value]) => (
                <div>
                  <span>{label}</span>
                  <strong>{value}</strong>
                </div>
              ))}
            </div>
          </div>

          <div class="featured-meta">
            <div>
              <h4>{page.projectsSection.scopeTitle}</h4>
              <ul class="featured-highlights">
                {page.featuredProject.highlights.map((highlight) => <li>{highlight}</li>)}
              </ul>
            </div>

            <div>
              <h4>{page.projectsSection.stackTitle}</h4>
              <div class="tags">
                {page.featuredProject.stack.map((item) => <span>{item}</span>)}
              </div>
            </div>

            <a href={page.featuredProject.link} target="_blank" rel="noopener noreferrer">{page.projectsSection.featuredRepositoryLabel}</a>
          </div>
        </article>

        <div class="project-subhead-card">
          <div>
            <p>{page.projectsSection.otherEyebrow}</p>
            <h3>{page.projectsSection.otherTitle}</h3>
          </div>
        </div>

        <div class="projects-grid">
          {page.projects.map((project) => (
            <article class="project-card">
              <h3>{project.title}</h3>
              <p>{project.description}</p>

              <div class="tags">
                {project.stack.map((item) => <span>{item}</span>)}
              </div>

              <div class="project-links">
               {"liveUrl" in project && project.liveUrl && (
                  <a class="project-link live" href={project.liveUrl} target="_blank" rel="noopener noreferrer">{page.projectsSection.liveSiteLabel}</a>
                )}
                <a class="project-link" href={project.link} target="_blank" rel="noopener noreferrer">{page.projectsSection.repositoryLabel}</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="section contact">
        <div>
          <p class="status danger">{page.contactSection.eyebrow}</p>
          <h2>{page.contactSection.title}</h2>
          <p class="contact-intro">{page.contactSection.intro}</p>
        </div>

        <div class="contact-panel">
          <div>
            <span>{page.contactSection.emailLabel}</span>
            <a href={`mailto:${portfolioLinks.email}`}>{portfolioLinks.email}</a>
          </div>

          <div>
            <span>{page.contactSection.locationLabel}</span>
            <strong>{page.contactSection.locationValue}</strong>
          </div>

          <div>
            <span>{page.contactSection.availabilityLabel}</span>
            <strong>{page.contactSection.availabilityValue}</strong>
          </div>

          <div>
            <span>{page.contactSection.profilesLabel}</span>
            <a href={portfolioLinks.github} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={portfolioLinks.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </div>
        </div>
      </section>

      <footer class="footer">
        <p>{page.footer}</p>
      </footer>
    </main>
    <script>
      const sideNavLinks = Array.from(
        document.querySelectorAll<HTMLAnchorElement>('.side-nav a')
      );

      const trackedSections = sideNavLinks
        .map((link) => {
          const sectionId = link.dataset.section;
          return sectionId ? document.getElementById(sectionId) : null;
        })
        .filter((section): section is HTMLElement => section !== null);

      const setActiveSection = (sectionId: string) => {
        sideNavLinks.forEach((link) => {
          link.classList.toggle('active', link.dataset.section === sectionId);
        });
      };

      const updateActiveSection = () => {
        const scrollBottom = window.innerHeight + window.scrollY;
        const documentHeight = document.documentElement.scrollHeight;

        if (documentHeight - scrollBottom < 120) {
          setActiveSection('contact');
          return;
        }

        const referencePoint = window.innerHeight * 0.42;
        const currentSection = trackedSections
          .map((section) => ({
            id: section.id,
            distance: Math.abs(section.getBoundingClientRect().top - referencePoint),
          }))
          .sort((a, b) => a.distance - b.distance)[0];

        if (currentSection?.id) {
          setActiveSection(currentSection.id);
        }
      };

      updateActiveSection();
      window.addEventListener('scroll', updateActiveSection, { passive: true });
      window.addEventListener('resize', updateActiveSection);
    </script>
  </body>
</html>
