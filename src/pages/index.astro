    font-size: 16px;
  }

  .featured-label,
  .project-subhead-card p {
    margin: 0;
    color: #fb7185;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .featured-metrics {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
