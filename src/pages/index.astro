---
const projects = [
  {
    title: "AWS Ephemeral Web Platform",
    description:
      "Personal infrastructure project designed around reproducibility, secure administration, automation, and cost-aware lifecycle management.",
    stack: ["AWS", "Terraform", "Ansible", "Docker", "SSM", "GitHub Actions"],
    link: "https://github.com/Badis-M/aws-ephemeral-web-platform",
  },
  {
    title: "AWS EKS Observability Platform",
    description:
      "Personal Kubernetes infrastructure project used to validate EKS provisioning, Helm-based tooling, and observability foundations.",
    stack: ["AWS EKS", "Terraform", "Kubernetes", "Helm", "Prometheus", "Grafana"],
    link: "https://github.com/Badis-M/aws-eks-observability-platform",
  },
  {
    title: "Pokédex DevOps Deployment Lab",
    description:
      "Personal DevOps deployment lab taking a Node.js application through Docker, AWS infrastructure, HTTPS, DNS, Ansible, and CI.",
    stack: ["Node.js", "Docker", "Terraform", "Ansible", "AWS", "Caddy", "OVH DNS"],
    link: "https://github.com/Badis-M/pokedex-devops-deployment-lab",
  },
];

const skills = [
  ["Cloud Platforms", "OCI, AWS, Azure"],
  ["Infrastructure as Code", "Terraform"],
  ["Automation", "Bash, GitHub Actions, CI/CD"],
  ["Containers", "Docker, Kubernetes, EKS, Helm"],
  ["Configuration", "Ansible, Server provisioning, Service Configuration"],
  ["Security", "IAM, SSO, cloud governance"],
  ["Networking", "VPC, DNS, HTTPS, secure connectivity"],
  ["Linux & Systems", "Linux administration, patching, troubleshooting"],
  ["Databases", "MySQL, ATP, Database migration support, operational maintenance"],
  ["Data Workflows", "ETL workflows, data handling, data processing"],
  ["Operations", "Monitoring, auditing, incident support"],
  ["Cost Control", "FinOps, cleanup automation, budget alerts"],
  ["Client Delivery", "Workshops, stakeholder support, consulting"],
  ["Tooling", "Git, GitHub, VS Code, CLI workflows"],
  ["Web Delivery", "Reverse proxy, HTTPS, DNS integration"],
];

const clientEnvironments = ["Rothschild", "Corner Bank", "Avaloq", "ISO", "LEMO", "CHUV", "IEC", "Keytrade"];

const missionAreas = [
  "Cloud infrastructure delivery",
  "Secure file transfer environments",
  "Containerized environments",
  "Kubernetes and Helm-based deployments",
  "Database migration support",
  "Terraform automation",
  "ETL workflows and data processing",
  "Infrastructure operations",
  "IAM, SSO and governance",
  "Documentation and stakeholder support",
];

const additionalExperiences = [
  {
    role: "Engineering School Instructor",
    company: "Epitech",
    description:
      "Teaching and mentoring engineering students through technical projects, practical workshops, and skill development.",
    tags: ["Teaching", "Mentoring", "Workshops", "Technical guidance"],
  },
  {
    role: "Project Manager",
    company: "Operational coordination",
    description:
      "Project coordination experience involving planning, follow-up, stakeholder communication, and delivery support.",
    tags: ["Project coordination", "Planning", "Stakeholders", "Delivery"],
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Badis Merakchi | Cloud & DevOps Engineer</title>
    <meta
      name="description"
      content="Badis Merakchi — Cloud & DevOps Engineer focused on automation, Infrastructure as Code, cloud security, and cost-aware infrastructure delivery."
    />
  </head>

  <body>
    <main class="page">
      <header class="header">
        <a class="logo" href="/">Badis Merakchi</a>
        <nav>
          <a href="#skills">Skills</a>
          <a href="#experience">Experience</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-copy">
          <p class="status">Available near Geneva · Cloud / DevOps / Infrastructure</p>

          <h1>Cloud & DevOps Engineer building secure, automated cloud platforms.</h1>

          <p class="lead">
            Consultant focused on Infrastructure as Code, cloud security, CI/CD,
            automation, and cost-aware infrastructure delivery across OCI, AWS,
            and Azure.
          </p>

          <div class="actions">
            <a class="button primary" href="/Badis-Merakchi-CV.pdf">Download CV</a>
            <a class="button secondary" href="https://github.com/Badis-M" target="_blank">GitHub ↗</a>
            <a class="button secondary" href="https://www.linkedin.com/in/merakchi" target="_blank">LinkedIn ↗</a>
          </div>
        </div>

        <aside class="profile-card">
          <div class="card-header">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="metric">
            <p>Role</p>
            <strong>Cloud & DevOps Engineer</strong>
          </div>

          <div class="metric">
            <p>Focus</p>
            <strong>Automation · IaC · Security · FinOps</strong>
          </div>

          <div class="metric">
            <p>Cloud</p>
            <strong>OCI · AWS · Azure</strong>
          </div>

          <div class="metric">
            <p>Location</p>
            <strong>Geneva area</strong>
          </div>
        </aside>
      </section>

      <section id="skills" class="section">
        <div class="section-head">
          <p>Technical scope</p>
          <h2>Core skills</h2>
        </div>

        <div class="skills-grid">
          {skills.map(([label, value]) => (
            <div class="skill-card">
              <span>{label}</span>
              <strong>{value}</strong>
            </div>
          ))}
        </div>
      </section>

      <section id="experience" class="section">
        <div class="section-head">
          <p>Experience</p>
          <h2>Cloud consulting across multiple client environments</h2>
        </div>

        <article class="experience">
          <div class="experience-header">
            <div>
              <h3>Oracle — Cloud Consultant</h3>
              <span>Geneva, Switzerland</span>
            </div>

            <p>
              Cloud consulting and infrastructure delivery across multiple Swiss
              client environments, including banking, financial services,
              industrial, and data-oriented contexts.
            </p>
          </div>

          <div class="experience-columns">
            <div>
              <h4>Client environments</h4>
              <div class="client-list">
                {clientEnvironments.map((client) => <span>{client}</span>)}
              </div>
            </div>

            <div>
              <h4>Mission areas</h4>
              <div class="mission-list">
                {missionAreas.map((mission) => <span>{mission}</span>)}
              </div>
            </div>
          </div>
        </article>

        <div class="additional-experience-grid">
          {additionalExperiences.map((item) => (
            <article class="additional-experience-card">
              <div>
                <span>{item.company}</span>
                <h3>{item.role}</h3>
              </div>

              <p>{item.description}</p>

              <div class="compact-tags">
                {item.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="section">
        <div class="section-head">
          <p>Personal projects</p>
          <h2>Hands-on Cloud & DevOps projects built to validate real infrastructure patterns</h2>
        </div>

        <div class="projects-grid">
          {projects.map((project) => (
            <article class="project-card">
              <h3>{project.title}</h3>
              <p>{project.description}</p>

              <div class="tags">
                {project.stack.map((item) => <span>{item}</span>)}
              </div>

              <a href={project.link} target="_blank">View repository →</a>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="section contact">
        <div>
          <p class="status danger">Contact</p>
          <h2>Let’s discuss Cloud, DevOps, and infrastructure delivery.</h2>
          <p class="contact-intro">
            Available for Cloud & DevOps engineering roles, consulting opportunities,
            and infrastructure automation projects around Geneva and Switzerland.
          </p>
        </div>

        <div class="contact-panel">
          <div>
            <span>Email</span>
            <a href="mailto:badis.merakchi@gmail.com">badis.merakchi@gmail.com</a>
          </div>

          <div>
            <span>Location</span>
            <strong>Geneva area</strong>
          </div>

          <div>
            <span>Availability</span>
            <strong>Open to Cloud & DevOps opportunities</strong>
          </div>

          <div>
            <span>Profiles</span>
            <a href="https://github.com/Badis-M" target="_blank">GitHub</a>
            <a href="https://www.linkedin.com/in/merakchi" target="_blank">LinkedIn</a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #07111f;
    color: #e5edf7;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at 82% 0%, rgba(14, 165, 233, 0.17), transparent 34rem),
      radial-gradient(circle at 8% 18%, rgba(248, 113, 113, 0.09), transparent 28rem),
      linear-gradient(180deg, #07111f 0%, #0a1220 55%, #070b12 100%);
  }

  a {
    color: inherit;
  }

  .page {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 28px 0;
  }

  .logo {
    color: #f8fafc;
    font-weight: 800;
    text-decoration: none;
    letter-spacing: -0.04em;
  }

  nav {
    display: flex;
    gap: 22px;
  }

  nav a {
    color: #94a3b8;
    font-size: 14px;
    text-decoration: none;
  }

  nav a:hover {
    color: #e2e8f0;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) 0.85fr;
    gap: 40px;
    align-items: center;
    padding: 70px 0 82px;
  }

  .status,
  .section-head p {
    margin: 0 0 14px;
    color: #38bdf8;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .status.danger {
    color: #fb7185;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 22px;
    color: #f8fafc;
    font-size: clamp(44px, 6vw, 78px);
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .lead {
    max-width: 690px;
    color: #cbd5e1;
    font-size: 20px;
    line-height: 1.65;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .button {
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 12px;
    padding: 12px 16px;
    color: #e2e8f0;
    font-weight: 800;
    text-decoration: none;
    background: rgba(15, 23, 42, 0.72);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: rgba(56, 189, 248, 0.5);
    background: rgba(15, 23, 42, 0.96);
  }

  .button.primary {
    background: #38bdf8;
    border-color: #38bdf8;
    color: #06111f;
  }

  .button.primary:hover {
    background: #7dd3fc;
    border-color: #7dd3fc;
  }

  .button.secondary:hover {
    color: #f8fafc;
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.08);
  }

  .profile-card,
  .project-card,
  .skill-card,
  .experience,
  .additional-experience-card,
  .contact-panel {
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 22px;
    background: rgba(15, 23, 42, 0.78);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  }

  .profile-card {
    padding: 22px;
  }

  .card-header {
    display: flex;
    gap: 8px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.16);
  }

  .card-header span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
  }

  .card-header span:nth-child(1) {
    background: #fb7185;
  }

  .card-header span:nth-child(2) {
    background: #fbbf24;
  }

  .card-header span:nth-child(3) {
    background: #38bdf8;
  }

  .metric {
    padding: 18px 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .metric:last-child {
    border-bottom: 0;
  }

  .metric p {
    margin-bottom: 6px;
    color: #64748b;
    font-size: 13px;
  }

  .metric strong {
    color: #e2e8f0;
  }

  .section {
    padding: 70px 0;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
  }

  .section-head {
    margin-bottom: 28px;
  }

  h2 {
    max-width: 820px;
    color: #f8fafc;
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.08;
    letter-spacing: -0.055em;
  }

  h3 {
    color: #f8fafc;
    font-size: 20px;
    letter-spacing: -0.03em;
  }

  h4 {
    margin: 0 0 16px;
    color: #94a3b8;
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  p,
  li {
    color: #cbd5e1;
    line-height: 1.7;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }

  .skill-card {
    padding: 18px;
  }

  .skill-card span {
    display: block;
    margin-bottom: 10px;
    color: #64748b;
    font-size: 13px;
    font-weight: 800;
  }

  .skill-card strong {
    color: #e2e8f0;
    font-size: 15px;
    line-height: 1.45;
  }

  .experience {
    padding: 28px;
  }

  .experience-header {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: 32px;
    margin-bottom: 30px;
  }

  .experience-header span {
    display: block;
    margin-top: 8px;
    color: #64748b;
    font-size: 14px;
  }

  .experience-header p {
    margin-bottom: 0;
  }

  .experience-columns {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: 28px;
    padding-top: 26px;
    border-top: 1px solid rgba(148, 163, 184, 0.12);
  }

  .additional-experience-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin-top: 18px;
  }

  .additional-experience-card {
    padding: 22px;
  }

  .additional-experience-card > div:first-child span {
    display: block;
    margin-bottom: 8px;
    color: #fb7185;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .additional-experience-card p {
    margin-bottom: 18px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .project-card {
    display: flex;
    min-height: 310px;
    flex-direction: column;
    padding: 24px;
  }

  .project-card:hover,
  .skill-card:hover,
  .additional-experience-card:hover {
    border-color: rgba(56, 189, 248, 0.3);
    transform: translateY(-2px);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }

  .project-card p {
    margin-bottom: 20px;
  }

  .project-card a {
    margin-top: auto;
    color: #38bdf8;
    font-weight: 800;
    text-decoration: none;
  }

  .project-card a:hover {
    color: #7dd3fc;
  }

  .tags,
  .client-list,
  .mission-list,
  .compact-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags {
    margin-bottom: 22px;
  }

  .tags span,
  .client-list span,
  .mission-list span,
  .compact-tags span {
    border: 1px solid rgba(56, 189, 248, 0.2);
    border-radius: 999px;
    padding: 6px 9px;
    color: #bae6fd;
    font-size: 12px;
    background: rgba(56, 189, 248, 0.08);
  }

  .client-list span {
    border-color: rgba(251, 113, 133, 0.24);
    color: #fecdd3;
    background: rgba(251, 113, 133, 0.08);
  }

  .mission-list span {
    border-radius: 12px;
  }

  .compact-tags span {
    border-color: rgba(148, 163, 184, 0.18);
    color: #cbd5e1;
    background: rgba(148, 163, 184, 0.08);
  }

  .contact {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 40px;
    padding-bottom: 90px;
  }

  .contact-intro {
    max-width: 680px;
    margin-top: 18px;
    color: #cbd5e1;
    font-size: 17px;
  }

  .contact-panel {
    display: grid;
    gap: 14px;
    padding: 24px;
    border-color: rgba(251, 113, 133, 0.22);
    background:
      linear-gradient(135deg, rgba(251, 113, 133, 0.08), transparent 42%),
      rgba(15, 23, 42, 0.78);
  }

  .contact-panel div {
    display: grid;
    gap: 5px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .contact-panel div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .contact-panel span {
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .contact-panel strong,
  .contact-panel a {
    color: #e2e8f0;
    font-weight: 800;
    text-decoration: none;
  }

  .contact-panel a:hover {
    color: #fb7185;
  }

  @media (max-width: 1000px) {
    .skills-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .projects-grid,
    .hero,
    .experience-header,
    .experience-columns,
    .additional-experience-grid,
    .contact {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 900px) {
    nav {
      display: none;
    }

    .hero {
      padding: 48px 0 60px;
    }
  }

  @media (max-width: 640px) {
    .page {
      width: min(100% - 28px, 1180px);
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: clamp(40px, 13vw, 58px);
    }
  }
</style>
